{
	"version": 3,
	"cmakeMinimumRequired": { "major": 3, "minor": 24, "patch": 0 },
	"configurePresets": [
		{
			"name": "mingw-debug",
			"displayName": "MinGW Debug (Ninja)",
			"generator": "Ninja",
			"binaryDir": "${sourceDir}/build/mingw-debug",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Debug",
				"CMAKE_C_COMPILER": "gcc",
				"CMAKE_CXX_COMPILER": "g++"
			}
		},
		{
			"name": "mingw-release",
			"inherits": "mingw-debug",
			"displayName": "MinGW Release (Ninja)",
			"binaryDir": "${sourceDir}/build/mingw-release",
			"cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
		},
		{
			"name": "msvc-debug",
			"displayName": "MSVC Debug (VS2022 x64)",
			"generator": "Visual Studio 17 2022",
			"architecture": "x64",
			"binaryDir": "${sourceDir}/build/msvc-debug",
			"cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
		},
		{
			"name": "msvc-release",
			"inherits": "msvc-debug",
			"displayName": "MSVC Release (VS2022 x64)",
			"binaryDir": "${sourceDir}/build/msvc-release",
			"cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
		}
	],
	"buildPresets": [
		{ "name": "mingw-debug",   "configurePreset": "mingw-debug" },
		{ "name": "mingw-release", "configurePreset": "mingw-release" },
		{ "name": "msvc-debug",    "configurePreset": "msvc-debug" },
		{ "name": "msvc-release",  "configurePreset": "msvc-release" }
	]
}
