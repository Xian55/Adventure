root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cpp,h,hpp,c}]
indent_style = tab
indent_size = 4

[*.{cmake,json,yml,yaml,js,md,lua}]
indent_style = space
indent_size = 2

[CMakeLists.txt]
indent_style = space
indent_size = 4

# Vendored — leave as-is.
[deps/**]
trim_trailing_whitespace = false
insert_final_newline = false
